{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": "./node_modules/.tmp/config",
    "tsBuildInfoFile": "./node_modules/.tmp/config/node.tsbuildinfo"
  },
  "include": ["vite.config.ts", "vitest.config.ts"]
}
